# Backend Environment Variables
# Copy this to .env in the backend/ folder, or set on your hosting platform (Railway, Render, etc.)

# --- REQUIRED ---
# PostgreSQL database connection
POSTGRES_SERVER=your-db-host.neon.tech
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=avanta
POSTGRES_PORT=5432

# JWT Secret - CHANGE THIS to a long random string in production!
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_IN_PRODUCTION

# --- OPTIONAL ---
# Google Gemini API key (for AI assistant, crawler, proposals)
GEMINI_API_KEY=AIza...

# Google OAuth (if using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
